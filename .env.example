# Site URL (used for auth redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — from `supabase start` output or your hosted project
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Calendar + Tasks integration (M3) — separate from Supabase Auth Google login
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Optional: encrypt integration tokens at rest (recommended for production)
INTEGRATION_ENCRYPTION_KEY=generate-a-long-random-string

# Cron auth for /api/cron/sync (Vercel Cron or manual)
SYNC_CRON_SECRET=generate-another-random-string