# Site URL (used for auth redirects and Google OAuth callbacks)
# Local only: http://localhost:3000
# LAN testing: npm run dev:lan auto-sets this to your machine's IP
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Supabase — from `supabase start` output or your hosted project
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Google Calendar + Tasks integration (M3) — separate from Supabase Auth Google login
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# Optional: encrypt integration tokens at rest (recommended for production)
INTEGRATION_ENCRYPTION_KEY=generate-a-long-random-string

# Cron auth for /api/cron/sync and /api/cron/digest
# Local manual run: npm run digest:run (uses Bearer token)
# Vercel: vercel.json schedules GET /api/cron/digest daily + /api/cron/sync every 6h
SYNC_CRON_SECRET=generate-another-random-string

# Zapier/Make ingest for Apple Reminders → POST /api/webhooks/zapier
ZAPIER_WEBHOOK_SECRET=generate-another-random-string